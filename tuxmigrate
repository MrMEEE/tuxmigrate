def cmd_build(args: argparse.Namespace) -> None:
    """Increment version, absorb changes into role, rebuild RPM."""

    # 1. Discover pending change files
    changes_path = Path(CHANGES_DIR)
    pending = sorted(
        p for p in changes_path.iterdir()
        if p.suffix in {".yml", ".yaml"} and p.is_file()
    )

    if not pending:
        die(
            f"No YAML task files found in '{CHANGES_DIR}/'. "
            "Add at least one task file before building."
        )

    print(f"Found {len(pending)} pending change(s):")
    for p in pending:
        print(f"  {p.name}")

    # 2. Load state (bootstrap on first run)
    data = load_config()
    if data is None:
        print(f"{CONFIG_FILE} not found — initialising new project.")
        print("Press Enter to accept the [default] or type a new value.\n")
        data = default_config()
        data["package_name"] = prompt_field("Package name", args.package_name, DEFAULT_PACKAGE_NAME)
        data["maintainer"] = prompt_field("Maintainer", args.maintainer, DEFAULT_MAINTAINER)
        data["description"] = prompt_field("Description", args.description, DEFAULT_DESCRIPTION)
        save_config(data)
        print(f"\nCreated {CONFIG_FILE} (version 1.0.0)\n")

    old_version = data["version"]
    new_version = increment_version(old_version, args.bump)
    print(f"Bumping version ({args.bump}): {old_version} -> {new_version}")

    # 3. Move and rename change files into the role
    playbooks_path = Path(ROLE_PLAYBOOKS_DIR)
    playbooks_path.mkdir(parents=True, exist_ok=True)

    new_entries: list[str] = []
    for idx, src in enumerate(pending, start=1):
        dest_name = f"{new_version}_{idx:02d}_{src.name}"
        dest = playbooks_path / dest_name
        shutil.move(str(src), str(dest))
        new_entries.append(dest_name)
        print(f"  Moved: {src.name} -> role/playbooks/{dest_name}")

    # 4. Update config
    data["version"] = new_version
    data.setdefault("playbooks", []).extend(new_entries)
    save_config(data)

    # 5. Regenerate role/tasks/main.yml
    tasks_path = Path(ROLE_TASKS_DIR)
    tasks_path.mkdir(parents=True, exist_ok=True)
    tasks_content = generate_tasks_main(data["playbooks"])
    tasks_file = tasks_path / "main.yml"
    tasks_file.write_text(tasks_content)
    print(f"\nRegenerated {tasks_file}")

    # 6. Build the RPM
    package_name = args.package_name or data.get("package_name", DEFAULT_PACKAGE_NAME)
    maintainer = args.maintainer or data.get("maintainer", DEFAULT_MAINTAINER)
    description = args.description or data.get(
        "description", DEFAULT_DESCRIPTION
    )
    builder = (args.builder or data.get("builder") or "fpm").strip().lower()
    if builder not in VALID_BUILDERS:
        die(f"Unknown builder '{builder}'. Use one of: {', '.join(sorted(VALID_BUILDERS))}.")

    # Persist build metadata for future builds
    data["package_name"] = package_name
    data["maintainer"] = maintainer
    data["description"] = description
    data["builder"] = builder
    save_config(data)

    if builder == "fpm":
        rpm_path = build_with_fpm(package_name, new_version, maintainer, description)
    else:
        rpm_path = build_with_rpmbuild(package_name, new_version, description)

    push_requested = data.get("satellite", {}).get("auto_push", False)
    if args.push is not None:
        push_requested = args.push

    print(f"\nBuild complete: {rpm_path.name}")
    print(
        f"Install with:  sudo rpm -Uvh {rpm_path.name}\n"
        f"               or: sudo dnf install ./{rpm_path.name}"
    )

    if push_requested:
        push_rpm_to_satellite(rpm_path, data.get("satellite", {}))


def cmd_status(args: argparse.Namespace) -> None:
    """Show current version and registered playbooks."""
    data = load_config()
    if data is None:
        print(f"{CONFIG_FILE} not found. Run 'tuxmigrate build' to initialise the project.")
        return
    print(f"Package : {data.get('package_name', 'tuxmigrate')}")
    print(f"Version : {data['version']}")
    print(f"Builder : {data.get('builder', 'fpm')}")

    satellite = data.get("satellite", {})
    if satellite.get("servername") or satellite.get("repository_id"):
        print(
            "Satellite: "
            f"server={satellite.get('servername') or '(unset)'} "
            f"repository_id={satellite.get('repository_id') or '(unset)'} "
            f"auto_push={coerce_bool(satellite.get('auto_push'), False)} "
            f"verifyssl={coerce_bool(satellite.get('verifyssl'), True)}"
        )
    else:
        print("Satellite: not configured")

    playbooks = data.get("playbooks", [])
    if not playbooks:
        print("Playbooks: (none yet)")
    else:
        print(f"Playbooks ({len(playbooks)}):")
        for pb in playbooks:
            print(f"  {pb}")

    changes_path = Path(CHANGES_DIR)
    pending = sorted(
        p.name
        for p in changes_path.iterdir()
        if p.suffix in {".yml", ".yaml"} and p.is_file()
    )
    if pending:
        print(f"\nPending changes ({len(pending)}) - ready for next build:")
        for name in pending:
            print(f"  {name}")
    else:
        print("\nNo pending changes.")


def cmd_config(args: argparse.Namespace) -> None:
    """Initialize, view, or update config.json values."""
    data = load_config()
    changed = False
    requested_change = config_change_requested(args)

    if data is None:
        if args.init or requested_change:
            data = default_config()
            changed = True
            print(f"Initialised {CONFIG_FILE} with defaults.")
        else:
            print(f"{CONFIG_FILE} not found. Run 'tuxmigrate config --init' to create it.")
            return

    if args.package_name is not None:
        data["package_name"] = args.package_name
        changed = True
    if args.maintainer is not None:
        data["maintainer"] = args.maintainer
        changed = True
    if args.description is not None:
        data["description"] = args.description
        changed = True
    if args.builder is not None:
        data["builder"] = args.builder
        changed = True

    satellite = data.setdefault("satellite", default_config()["satellite"])
    if args.satellite_servername is not None:
        satellite["servername"] = args.satellite_servername.strip()
        changed = True
    if args.satellite_username is not None:
        satellite["username"] = args.satellite_username.strip()
        changed = True
    if args.satellite_password is not None:
        satellite["password"] = args.satellite_password
        changed = True
    if args.satellite_repository_id is not None:
        satellite["repository_id"] = args.satellite_repository_id.strip()
        changed = True
    if args.satellite_verifyssl is not None:
        satellite["verifyssl"] = args.satellite_verifyssl
        changed = True
    if args.satellite_auto_push is not None:
        satellite["auto_push"] = args.satellite_auto_push
        changed = True

    data = normalize_config(data)
    if changed:
        save_config(data)
        print(f"Saved {CONFIG_FILE}.")

    if args.show or (not requested_change and not args.init):
        rendered = redact_config(data, show_secrets=args.show_secrets)
        print(json.dumps(rendered, indent=2))


# ---------------------------------------------------------------------------
# Path helpers (keep install layout consistent)
# ---------------------------------------------------------------------------


def _rpm_role_path(package_name: str) -> str:
    return f"/usr/share/{package_name}/role"


def _rpm_site_yml_path(package_name: str) -> str:
    return f"/usr/share/{package_name}/site.yml"


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="tuxmigrate",
        description="RPM-based Ansible configuration migration tool.",
    )
    sub = parser.add_subparsers(dest="command", metavar="COMMAND")

    # build
    build_p = sub.add_parser(
        "build",
        help="Absorb pending changes, bump version, and produce an RPM.",
    )
    build_p.add_argument(
        "--package-name",
        metavar="NAME",
        help="RPM package name (default: value from config.json or 'tuxmigrate').",
    )
    build_p.add_argument(
        "--maintainer",
        metavar="EMAIL",
        help="RPM maintainer field.",
    )
    build_p.add_argument(
        "--description",
        metavar="TEXT",
        help="RPM description / summary.",
    )
    build_p.add_argument(
        "--builder",
        choices=sorted(VALID_BUILDERS),
        help="RPM build backend to use (default: value from config.json or fpm).",
    )
    push_group = build_p.add_mutually_exclusive_group()
    push_group.add_argument(
        "--push",
        dest="push",
        action="store_true",
        default=None,
        help="Upload the built RPM to Satellite/Katello after a successful build.",
    )
    push_group.add_argument(
        "--no-push",
        dest="push",
        action="store_false",
        help="Do not upload the built RPM to Satellite/Katello for this build.",
    )
    bump_group = build_p.add_mutually_exclusive_group()
    bump_group.add_argument(
        "--major",
        dest="bump",
        action="store_const",
        const="major",
        help="Bump the major version (e.g. 1.2.3 -> 2.0.0).",
    )
    bump_group.add_argument(
        "--minor",
        dest="bump",
        action="store_const",
        const="minor",
        help="Bump the minor version (e.g. 1.2.3 -> 1.3.0).",
    )
    bump_group.add_argument(
        "--patch",
        dest="bump",
        action="store_const",
        const="patch",
        help="Bump the patch version (e.g. 1.2.3 -> 1.2.4) [default].",
    )
    build_p.set_defaults(func=cmd_build, bump="patch")

    # status
    status_p = sub.add_parser(
        "status",
        help="Show current version and pending changes.",
    )
    status_p.set_defaults(func=cmd_status)

    # config
    config_p = sub.add_parser(
        "config",
        help="Initialize, show, or update config.json values.",
    )
    config_p.add_argument(
        "--init",
        action="store_true",
        help="Create config.json with defaults if it does not exist.",
    )
    config_p.add_argument(
        "--show",
        action="store_true",
        help="Print current config.json values (password is redacted by default).",
    )
    config_p.add_argument(
        "--show-secrets",
        action="store_true",
        help="When used with --show, print secret values such as satellite.password.",
    )
    config_p.add_argument(
        "--package-name",
        metavar="NAME",
        help="Set package_name in config.json.",
    )
    config_p.add_argument(
        "--maintainer",
        metavar="EMAIL",
        help="Set maintainer in config.json.",
    )
    config_p.add_argument(
        "--description",
        metavar="TEXT",
        help="Set description in config.json.",
    )
    config_p.add_argument(
        "--builder",
        choices=sorted(VALID_BUILDERS),
        help="Set default build backend in config.json.",
    )
    config_p.add_argument(
        "--satellite-servername",
        metavar="URL_OR_HOST",
        help="Set satellite.servername in config.json.",
    )
    config_p.add_argument(
        "--satellite-username",
        metavar="USER",
        help="Set satellite.username in config.json.",
    )
    config_p.add_argument(
        "--satellite-password",
        metavar="PASS",
        help="Set satellite.password in config.json.",
    )
    config_p.add_argument(
        "--satellite-repository-id",
        metavar="ID",
        help="Set satellite.repository_id in config.json.",
    )
    satellite_ssl_group = config_p.add_mutually_exclusive_group()
    satellite_ssl_group.add_argument(
        "--satellite-verifyssl",
        dest="satellite_verifyssl",
        action="store_true",
        default=None,
        help="Set satellite.verifyssl=true.",
    )
    satellite_ssl_group.add_argument(
        "--satellite-no-verifyssl",
        dest="satellite_verifyssl",
        action="store_false",
        help="Set satellite.verifyssl=false.",
    )
    satellite_push_group = config_p.add_mutually_exclusive_group()
    satellite_push_group.add_argument(
        "--satellite-auto-push",
        dest="satellite_auto_push",
        action="store_true",
        default=None,
        help="Set satellite.auto_push=true.",
    )
    satellite_push_group.add_argument(
        "--satellite-no-auto-push",
        dest="satellite_auto_push",
        action="store_false",
        help="Set satellite.auto_push=false.",
    )
    config_p.set_defaults(func=cmd_config)

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(0)

    args.func(args)


if __name__ == "__main__":
    main()
