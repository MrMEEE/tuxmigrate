# Katello / Satellite helpers
# ---------------------------------------------------------------------------


def _kat_ssl_ctx(verify_ssl: bool) -> ssl.SSLContext:
    ctx = ssl.create_default_context()
    if not verify_ssl:
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
    return ctx


def _kat_admin_auth(admin_user: str, admin_pass: str) -> str:
    """Return a Basic auth header value for admin username/password."""
    return "Basic " + base64.b64encode(f"{admin_user}:{admin_pass}".encode()).decode()


def _kat_request(
    url: str, auth: str, method: str, path: str,
    payload: dict | None = None, verify_ssl: bool = True,
) -> tuple[dict | None, str]:
    """Generic Satellite/Katello API call. Returns (body_dict_or_None, error_str)."""
    full_url = url.rstrip("/") + path
    data = json.dumps(payload).encode() if payload is not None else None
    req = urllib.request.Request(full_url, data=data, method=method)
    req.add_header("Authorization", auth)
    req.add_header("Content-Type", "application/json")
    req.add_header("Accept", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=30, context=_kat_ssl_ctx(verify_ssl)) as resp:
            return json.loads(resp.read().decode()), ""
    except urllib.error.HTTPError as exc:
        try:
            detail = exc.read().decode()
        except Exception:
            detail = ""
        return None, f"HTTP {exc.code}: {detail}"
    except Exception as exc:  # noqa: BLE001
        return None, str(exc)


def _kat_get(url: str, auth: str, path: str, verify_ssl: bool = True) -> tuple[dict | None, str]:
    return _kat_request(url, auth, "GET", path, verify_ssl=verify_ssl)


def _kat_post(
    url: str, auth: str, path: str, payload: dict, verify_ssl: bool = True,
) -> tuple[dict | None, str]:
    return _kat_request(url, auth, "POST", path, payload, verify_ssl)


def _kat_create_service_account(
    url: str, admin_auth: str, login: str, verify_ssl: bool = True,
) -> tuple[int | None, str]:
    """Create a local Foreman user for tuxmigrate. Returns (user_id, error)."""
    password = "".join(
        secrets.choice(string.ascii_letters + string.digits + "!@#$%^&*")
        for _ in range(32)
    )
    payload = {
        "user": {
            "login":          login,
            "firstname":      "TuxMigrate",
            "lastname":       "Service",
            "mail":           f"{login}@localhost.invalid",
            "password":       password,
            "auth_source_id": 1,   # 1 = internal database
            "admin":          False,
        }
    }
    result, err = _kat_post(url, admin_auth, "/api/v2/users", payload, verify_ssl)
    if err:
        return None, err
    return result["id"], ""


def _kat_create_role(
    url: str, admin_auth: str, role_name: str, verify_ssl: bool = True,
) -> tuple[int | None, str]:
    """Create a custom Foreman role. Returns (role_id, error)."""
    payload = {"role": {"name": role_name, "description": "Auto-created by tuxmigrate"}}
    result, err = _kat_post(url, admin_auth, "/api/v2/roles", payload, verify_ssl)
    if err:
        return None, err
    return result["id"], ""


def _kat_find_permission_ids(
    url: str, admin_auth: str, names: list[str], verify_ssl: bool = True,
) -> list[int]:
    """Return Foreman permission IDs for the given permission names."""
    ids: list[int] = []
    for name in names:
        path = "/api/v2/permissions?search=" + urllib.parse.quote(f"name = {name}") + "&per_page=5"
        result, err = _kat_get(url, admin_auth, path, verify_ssl)
        if err:
            print(f"    WARNING: could not look up permission '{name}': {err}", file=sys.stderr)
        elif result and result.get("results"):
            ids.append(result["results"][0]["id"])
    return ids


def _kat_create_filter(
    url: str, admin_auth: str, role_id: int, permission_ids: list[int], verify_ssl: bool = True,
) -> str:
    """Attach permissions to a role via a filter. Returns error string or empty."""
    payload = {
        "filter": {
            "role_id":        role_id,
            "permission_ids": permission_ids,
            "unlimited":      True,
        }
    }
    _, err = _kat_post(url, admin_auth, "/api/v2/filters", payload, verify_ssl)
    return err


def _kat_assign_role_to_user(
    url: str, admin_auth: str, user_id: int, role_id: int, verify_ssl: bool = True,
) -> str:
    """Assign a role to a user. Returns error string or empty."""
    _, err = _kat_post(
        url, admin_auth,
        f"/api/v2/users/{user_id}/roles",
        {"role_id": role_id},
        verify_ssl,
    )
    return err


def _kat_create_pat(
    url: str, admin_auth: str, user_id: int, token_name: str, verify_ssl: bool = True,
) -> tuple[str | None, str]:
    """Create a Personal Access Token for a user. Returns (token_value, error)."""
    path = f"/api/v2/users/{user_id}/personal_access_tokens"
    payload = {"personal_access_token": {"name": token_name}}
    result, err = _kat_post(url, admin_auth, path, payload, verify_ssl)
    if err:
        return None, err
    token_val = result.get("value") or result.get("token", "")
    return token_val or None, ""


def _kat_api_list(url: str, token: str, path: str, verify_ssl: bool = True) -> list[dict]:
    """Fetch a Katello API list using a Bearer token. Returns [] on failure."""
    result, _ = _kat_get(url, f"Bearer {token}", path + "?per_page=200", verify_ssl)
    if result is None:
        return []
    return result.get("results", result) if isinstance(result, dict) else result


def _kat_pick(label: str, items: list[dict], default: str) -> str:
    """Present a numbered list of Satellite items and return the chosen name.
    Falls back to free-text entry if the list is empty.
    """
    if not items:
        answer = input(f"  {label} (could not fetch list) [{default}]: ").strip()
        return answer if answer else default
    print(f"\n  Available {label}s:")
    for i, item in enumerate(items, start=1):
        print(f"    {i}) {item['name']}")
    while True:
        raw = input(f"  Select {label} [1-{len(items)}] or type a name: ").strip()
        if not raw:
            return default
        if raw.isdigit():
            idx = int(raw) - 1
            if 0 <= idx < len(items):
                return items[idx]["name"]
            print(f"    Please enter a number between 1 and {len(items)}.")
        else:
            return raw


def _katello_token(katello_cfg: dict) -> str:
    """Return the Katello Personal Access Token.

    Precedence: KATELLO_TOKEN env var > token stored in versions.json > interactive prompt.
    """
    token = os.environ.get("KATELLO_TOKEN", "") or katello_cfg.get("token", "")
    if not token:
        token = input(f"  Katello Personal Access Token for {katello_cfg['url']}: ").strip()
    return token


def _push_katello(rpm_file: str, katello_cfg: dict) -> None:
    """Upload *rpm_file* to the configured Katello/Satellite repository via hammer."""
    if not Path(rpm_file).exists():
        print(f"WARNING: RPM file '{rpm_file}' not found, skipping Katello upload.", file=sys.stderr)
        return
    if not shutil.which("hammer"):
        print("WARNING: 'hammer' CLI not found — skipping Katello upload.", file=sys.stderr)
        print("         Install foreman-cli (yum install rubygem-hammer_cli_katello) and re-run:")
        print(f"         hammer repository upload-content \\"
              f"--organization '{katello_cfg['organization']}' \\"
              f"--product '{katello_cfg['product']}' \\"
              f"--name '{katello_cfg['repository']}' \\"
              f"--path {rpm_file}")
        return

    token = _katello_token(katello_cfg)

    cmd = [
        "hammer",
        "--server", katello_cfg["url"],
        "--token",  token,
        "repository", "upload-content",
        "--organization", katello_cfg["organization"],
        "--product",      katello_cfg["product"],
        "--name",         katello_cfg["repository"],
        "--path",         rpm_file,
    ]
    # Log the command with the token redacted
    safe = cmd[:4] + ["--token", "***"] + cmd[6:]
    print(f"\nPushing to Katello: {' '.join(safe)}")
    if subprocess.run(cmd).returncode != 0:
        print("ERROR: Katello upload failed. Check the output above.", file=sys.stderr)
    else:
        print(f"  Uploaded {rpm_file} to {katello_cfg['url']}")


def _build_fpm(package_name: str, version: str, maintainer: str, description: str) -> bool:
    cmd = [
        "fpm",
        "-s", "dir",
        "-t", "rpm",
        "-n", package_name,
        "-v", version,
        "--after-install", POST_INSTALL_SCRIPT,
        "--maintainer", maintainer,
        "--description", description,
        "--rpm-summary", description,
        "--force",
        f"{ROLE_DIR}/={_rpm_role_path(package_name)}/",
        f"{SITE_YML}={_rpm_site_yml_path(package_name)}",
    ]
    print(f"\nRunning: {' '.join(cmd)}\n")
    if subprocess.run(cmd).returncode != 0:
        print("ERROR: fpm failed. Check the output above for details.", file=sys.stderr)
        return False
    _print_install_hint(f"{package_name}-{version}-1.x86_64.rpm")
    return True


def _build_rpmbuild(
    package_name: str, version: str, maintainer: str, description: str
) -> bool:
    """Generate a minimal .spec file and invoke rpmbuild."""
    install_role = _rpm_role_path(package_name)
    install_site = _rpm_site_yml_path(package_name)
    install_dir  = f"/usr/share/{package_name}"

    spec_content = f"""%define _rpmdir %(pwd)

Name:        {package_name}
Version:     {version}
Release:     1%{{?dist}}
Summary:     {description}
License:     MIT
BuildArch:   noarch
Packager:    {maintainer}

%description
{description}

%install
mkdir -p %{{buildroot}}{install_role}
mkdir -p %{{buildroot}}{install_dir}
cp -r {ROLE_DIR}/* %{{buildroot}}{install_role}/
cp {SITE_YML} %{{buildroot}}{install_dir}/

%files
%{{_usr}}/share/{package_name}/

%post
bash {install_dir}/{POST_INSTALL_SCRIPT}

%changelog
* $(date '+%a %b %d %Y') {maintainer} - {version}-1
- tuxmigrate automated build
"""

    spec_file = Path(f"{package_name}.spec")
    spec_file.write_text(spec_content)
    print(f"\nWrote {spec_file}")

    # Copy post-install script to install dir so %post can reach it at install time
    # rpmbuild needs BUILD/BUILDROOT/RPMS/SOURCES/SPECS/SRPMS dirs
    for d in ["BUILD", "BUILDROOT", "RPMS", "SOURCES", "SPECS", "SRPMS"]:
        Path(d).mkdir(exist_ok=True)

    cmd = [
        "rpmbuild",
        "--define", f"_topdir {Path('.').resolve()}",
        "--define", f"_rpmfilename {package_name}-{version}-1.noarch.rpm",
        "-bb", str(spec_file),
    ]
    print(f"Running: {' '.join(cmd)}\n")
    if subprocess.run(cmd).returncode != 0:
        print("ERROR: rpmbuild failed. Check the output above for details.", file=sys.stderr)
        return False
    _print_install_hint(f"{package_name}-{version}-1.noarch.rpm")
    return True


