def main() -> None:
    parser = argparse.ArgumentParser(
        prog="tuxmigrate",
        description="RPM-based Ansible configuration migration tool.",
    )
    sub = parser.add_subparsers(dest="command", metavar="COMMAND")

    # build
    build_p = sub.add_parser(
        "build",
        help="Absorb pending changes, bump version, and produce an RPM.",
    )
    build_p.add_argument(
        "--package-name",
        metavar="NAME",
        help="RPM package name (default: value from versions.json or 'tuxmigrate').",
    )
    build_p.add_argument(
        "--maintainer",
        metavar="EMAIL",
        help="RPM maintainer field.",
    )
    build_p.add_argument(
        "--description",
        metavar="TEXT",
        help="RPM description / summary.",
    )
    build_p.add_argument(
        "--build-tool",
        metavar="TOOL",
        choices=SUPPORTED_BUILD_TOOLS,
        help="RPM build utility to use: fpm or rpmbuild (overrides versions.json).",
    )
    bump_group = build_p.add_mutually_exclusive_group()
    bump_group.add_argument(
        "--major",
        dest="bump",
        action="store_const",
        const="major",
        help="Bump the major version (e.g. 1.2.3 -> 2.0.0).",
    )
    bump_group.add_argument(
        "--minor",
        dest="bump",
        action="store_const",
        const="minor",
        help="Bump the minor version (e.g. 1.2.3 -> 1.3.0).",
    )
    bump_group.add_argument(
        "--patch",
        dest="bump",
        action="store_const",
        const="patch",
        help="Bump the patch version (e.g. 1.2.3 -> 1.2.4) [default].",
    )
    build_p.set_defaults(func=cmd_build, bump="patch")

    # status
    status_p = sub.add_parser(
        "status",
        help="Show current version and pending changes.",
    )
    status_p.set_defaults(func=cmd_status)

    args = parser.parse_args()
    ensure_config(args)
    if not args.command:
        parser.print_help()
        sys.exit(0)

    args.func(args)


if __name__ == "__main__":
    main()
