#!/usr/bin/env python3
"""
tuxmigrate - RPM-based Ansible configuration migration tool.

Works similarly to Alembic: place task files into changes/, run `tuxmigrate build`,
and an RPM is produced. Installing the RPM runs all unapplied changes on the host.
"""

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

VERSIONS_FILE = "versions.json"
CHANGES_DIR = "changes"
ROLE_DIR = "role"
ROLE_PLAYBOOKS_DIR = os.path.join(ROLE_DIR, "playbooks")
ROLE_TASKS_DIR = os.path.join(ROLE_DIR, "tasks")
SITE_YML = "site.yml"
POST_INSTALL_SCRIPT = "post-install.sh"
FACTS_DIR = "/etc/ansible/facts.d"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def die(msg: str) -> None:
    print(f"ERROR: {msg}", file=sys.stderr)
    sys.exit(1)


SUPPORTED_BUILD_TOOLS = ("fpm", "rpmbuild")


def prompt_field(label: str, cli_value: str | None, default: str) -> str:
    """Return cli_value if provided, otherwise prompt the user interactively."""
    if cli_value:
        return cli_value
    answer = input(f"  {label} [{default}]: ").strip()
    return answer if answer else default


def prompt_choice(label: str, cli_value: str | None, choices: tuple, default: str) -> str:
    """Prompt for a value that must be one of *choices*."""
    if cli_value:
        if cli_value not in choices:
            die(f"Invalid {label} '{cli_value}'. Choose from: {', '.join(choices)}.")
        return cli_value
    while True:
        answer = input(f"  {label} {list(choices)} [{default}]: ").strip()
        value = answer if answer else default
        if value in choices:
            return value
        print(f"    Please enter one of: {', '.join(choices)}")


def load_versions() -> dict | None:
    """Load versions.json. Returns None if the file does not exist yet."""
    if not Path(VERSIONS_FILE).exists():
        return None
    with open(VERSIONS_FILE) as fh:
        return json.load(fh)


def save_versions(data: dict) -> None:
    with open(VERSIONS_FILE, "w") as fh:
        json.dump(data, fh, indent=2)
        fh.write("\n")


def increment_version(version: str, bump: str = "minor") -> str:
    """Return a new version string with the requested component bumped.

    bump values:
      'major' - increment major, reset minor and patch to 0
      'minor' - increment minor, reset patch to 0  (default)
      'patch' - increment patch only
    """
    parts = version.split(".")
    if len(parts) != 3:
        die(f"Version '{version}' is not in MAJOR.MINOR.PATCH format.")
    major, minor, patch = (int(p) for p in parts)
    if bump == "major":
        return f"{major + 1}.0.0"
    elif bump == "minor":
        return f"{major}.{minor + 1}.0"
    elif bump == "patch":
        return f"{major}.{minor}.{patch + 1}"
    else:
        die(f"Unknown bump type '{bump}'. Use major, minor, or patch.")


def sanitize(name: str) -> str:
    """Replace any non-alphanumeric character with underscore."""
    return re.sub(r"[^a-zA-Z0-9]", "_", name)


def fact_name(playbook_filename: str) -> str:
    """Return the Ansible local fact name derived from a playbook filename.

    e.g. '1.2.0_01_install_vim.yml' -> 'tuxmigrate_1_2_0_01_install_vim'
    """
    stem = Path(playbook_filename).stem
    return f"tuxmigrate_{sanitize(stem)}"


def register_var(playbook_filename: str) -> str:
    """Return a unique Ansible register variable name for a playbook."""
    return f"_tm_fact_{sanitize(Path(playbook_filename).stem)}"


# ---------------------------------------------------------------------------
# Role task generation
# ---------------------------------------------------------------------------


def generate_tasks_main(playbooks: list[str]) -> str:
    """Generate the content of role/tasks/main.yml for the given ordered list
    of playbook filenames."""
    lines = [
        "---",
        "# Auto-generated by tuxmigrate - do not edit manually.",
        "# Re-run 'tuxmigrate build' to update.",
        "",
        "- name: Ensure facts directory exists",
        "  ansible.builtin.file:",
        f"    path: {FACTS_DIR}",
        "    state: directory",
        "    mode: '0755'",
        "",
    ]

    for pb in playbooks:
        fname = fact_name(pb)
        reg = register_var(pb)
        fact_path = f"{FACTS_DIR}/{fname}.fact"

        lines += [
            f"# --- {pb} ---",
            f"- name: Check whether '{pb}' has already been applied",
            f"  ansible.builtin.stat:",
            f"    path: {fact_path}",
            f"  register: {reg}",
            "",
            f"- name: Apply changes from '{pb}'",
            f"  ansible.builtin.include_tasks:",
            f"    file: playbooks/{pb}",
            f"  when: not {reg}.stat.exists",
            "",
            f"- name: Record '{pb}' as applied",
            f"  ansible.builtin.copy:",
            f'    content: |',
            f'      {{"applied": true, "playbook": "{pb}"}}',
            f"    dest: {fact_path}",
            f"    mode: '0644'",
            f"  when: not {reg}.stat.exists",
            "",
        ]

    return "\n".join(lines)


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------


def cmd_build(args: argparse.Namespace) -> None:
    """Increment version, absorb changes into role, rebuild RPM."""

    # 1. Discover pending change files
    changes_path = Path(CHANGES_DIR)
    pending = sorted(
        p for p in changes_path.iterdir()
        if p.suffix in {".yml", ".yaml"} and p.is_file()
    )

    if not pending:
        die(
            f"No YAML task files found in '{CHANGES_DIR}/'. "
            "Add at least one task file before building."
        )

    print(f"Found {len(pending)} pending change(s):")
    for p in pending:
        print(f"  {p.name}")

    # 2. Load state (bootstrap on first run)
    data = load_versions()
    if data is None:
        print(f"{VERSIONS_FILE} not found — initialising new project.")
        print("Press Enter to accept the [default] or type a new value.\n")
        package_name = prompt_field("Package name", args.package_name, "tuxmigrate")
        maintainer   = prompt_field("Maintainer",   args.maintainer,   "tuxmigrate")
        description  = prompt_field("Description",  args.description,  "TuxMigrate configuration management")
        build_tool   = prompt_choice("Build tool",   args.build_tool,   SUPPORTED_BUILD_TOOLS, "fpm")
        data = {
            "version": "1.0.0",
            "package_name": package_name,
            "maintainer": maintainer,
            "description": description,
            "build_tool": build_tool,
            "playbooks": [],
        }
        save_versions(data)
        print(f"\nCreated {VERSIONS_FILE} (version 1.0.0)\n")

    old_version = data["version"]
    new_version = increment_version(old_version, args.bump)
    print(f"Bumping version ({args.bump}): {old_version} -> {new_version}")

    # 3. Move and rename change files into the role
    playbooks_path = Path(ROLE_PLAYBOOKS_DIR)
    playbooks_path.mkdir(parents=True, exist_ok=True)

    new_entries: list[str] = []
    for idx, src in enumerate(pending, start=1):
        dest_name = f"{new_version}_{idx:02d}_{src.name}"
        dest = playbooks_path / dest_name
        shutil.move(str(src), str(dest))
        new_entries.append(dest_name)
        print(f"  Moved: {src.name} -> role/playbooks/{dest_name}")

    # 4. Update versions.json
    data["version"] = new_version
    data.setdefault("playbooks", []).extend(new_entries)
    save_versions(data)

    # 5. Regenerate role/tasks/main.yml
    tasks_path = Path(ROLE_TASKS_DIR)
    tasks_path.mkdir(parents=True, exist_ok=True)
    tasks_content = generate_tasks_main(data["playbooks"])
    tasks_file = tasks_path / "main.yml"
    tasks_file.write_text(tasks_content)
    print(f"\nRegenerated {tasks_file}")

    # 6. Resolve build metadata (CLI flag > versions.json > hardcoded default)
    package_name = args.package_name or data.get("package_name", "tuxmigrate")
    maintainer   = args.maintainer   or data.get("maintainer",   "tuxmigrate")
    description  = args.description  or data.get("description",  "TuxMigrate configuration management")
    build_tool   = args.build_tool   or data.get("build_tool",   "fpm")

    if build_tool not in SUPPORTED_BUILD_TOOLS:
        die(f"Unknown build_tool '{build_tool}' in {VERSIONS_FILE}. Choose from: {', '.join(SUPPORTED_BUILD_TOOLS)}.")

    # Persist build metadata for future builds
    data["package_name"] = package_name
    data["maintainer"]   = maintainer
    data["description"]  = description
    data["build_tool"]   = build_tool
    save_versions(data)

    # 7. Build the RPM
    if build_tool == "fpm":
        _build_fpm(package_name, new_version, maintainer, description)
    else:
        _build_rpmbuild(package_name, new_version, maintainer, description)


def cmd_status(args: argparse.Namespace) -> None:
    """Show current version and registered playbooks."""
    data = load_versions()
    if data is None:
        print(f"{VERSIONS_FILE} not found. Run 'tuxmigrate build' to initialise the project.")
        return
    print(f"Package    : {data.get('package_name', 'tuxmigrate')}")
    print(f"Version    : {data['version']}")
    print(f"Build tool : {data.get('build_tool', 'fpm')}")
    playbooks = data.get("playbooks", [])
    if not playbooks:
        print("Playbooks: (none yet)")
    else:
        print(f"Playbooks ({len(playbooks)}):")
        for pb in playbooks:
            print(f"  {pb}")

    changes_path = Path(CHANGES_DIR)
    pending = sorted(
        p.name
        for p in changes_path.iterdir()
        if p.suffix in {".yml", ".yaml"} and p.is_file()
    )
    if pending:
        print(f"\nPending changes ({len(pending)}) - ready for next build:")
        for name in pending:
            print(f"  {name}")
    else:
        print("\nNo pending changes.")


# ---------------------------------------------------------------------------
# Path helpers (keep install layout consistent)
# ---------------------------------------------------------------------------


def _rpm_role_path(package_name: str) -> str:
    return f"/usr/share/{package_name}/role"


def _rpm_site_yml_path(package_name: str) -> str:
    return f"/usr/share/{package_name}/site.yml"


def _print_install_hint(rpm_file: str) -> None:
    print(f"\nBuild complete: {rpm_file}")
    print(
        f"Install with:  sudo rpm -Uvh {rpm_file}\n"
        f"               or: sudo dnf install ./{rpm_file}"
    )


def _build_fpm(package_name: str, version: str, maintainer: str, description: str) -> None:
    cmd = [
        "fpm",
        "-s", "dir",
        "-t", "rpm",
        "-n", package_name,
        "-v", version,
        "--after-install", POST_INSTALL_SCRIPT,
        "--maintainer", maintainer,
        "--description", description,
        "--rpm-summary", description,
        "--force",
        f"{ROLE_DIR}/={_rpm_role_path(package_name)}/",
        f"{SITE_YML}={_rpm_site_yml_path(package_name)}",
    ]
    print(f"\nRunning: {' '.join(cmd)}\n")
    if subprocess.run(cmd).returncode != 0:
        die("fpm failed. Check the output above for details.")
    _print_install_hint(f"{package_name}-{version}-1.x86_64.rpm")


def _build_rpmbuild(
    package_name: str, version: str, maintainer: str, description: str
) -> None:
    """Generate a minimal .spec file and invoke rpmbuild."""
    install_role = _rpm_role_path(package_name)
    install_site = _rpm_site_yml_path(package_name)
    install_dir  = f"/usr/share/{package_name}"

    spec_content = f"""%define _rpmdir %(pwd)

Name:        {package_name}
Version:     {version}
Release:     1%{{?dist}}
Summary:     {description}
License:     MIT
BuildArch:   noarch
Packager:    {maintainer}

%description
{description}

%install
mkdir -p %{{buildroot}}{install_role}
mkdir -p %{{buildroot}}{install_dir}
cp -r {ROLE_DIR}/* %{{buildroot}}{install_role}/
cp {SITE_YML} %{{buildroot}}{install_dir}/

%files
%{{_usr}}/share/{package_name}/

%post
bash {install_dir}/{POST_INSTALL_SCRIPT}

%changelog
* $(date '+%a %b %d %Y') {maintainer} - {version}-1
- tuxmigrate automated build
"""

    spec_file = Path(f"{package_name}.spec")
    spec_file.write_text(spec_content)
    print(f"\nWrote {spec_file}")

    # Copy post-install script to install dir so %post can reach it at install time
    # rpmbuild needs BUILD/BUILDROOT/RPMS/SOURCES/SPECS/SRPMS dirs
    for d in ["BUILD", "BUILDROOT", "RPMS", "SOURCES", "SPECS", "SRPMS"]:
        Path(d).mkdir(exist_ok=True)

    cmd = [
        "rpmbuild",
        "--define", f"_topdir {Path('.').resolve()}",
        "--define", f"_rpmfilename {package_name}-{version}-1.noarch.rpm",
        "-bb", str(spec_file),
    ]
    print(f"Running: {' '.join(cmd)}\n")
    if subprocess.run(cmd).returncode != 0:
        die("rpmbuild failed. Check the output above for details.")
    _print_install_hint(f"{package_name}-{version}-1.noarch.rpm")


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="tuxmigrate",
        description="RPM-based Ansible configuration migration tool.",
    )
    sub = parser.add_subparsers(dest="command", metavar="COMMAND")

    # build
    build_p = sub.add_parser(
        "build",
        help="Absorb pending changes, bump version, and produce an RPM.",
    )
    build_p.add_argument(
        "--package-name",
        metavar="NAME",
        help="RPM package name (default: value from versions.json or 'tuxmigrate').",
    )
    build_p.add_argument(
        "--maintainer",
        metavar="EMAIL",
        help="RPM maintainer field.",
    )
    build_p.add_argument(
        "--description",
        metavar="TEXT",
        help="RPM description / summary.",
    )
    build_p.add_argument(
        "--build-tool",
        metavar="TOOL",
        choices=SUPPORTED_BUILD_TOOLS,
        help="RPM build utility to use: fpm or rpmbuild (overrides versions.json).",
    )
    bump_group = build_p.add_mutually_exclusive_group()
    bump_group.add_argument(
        "--major",
        dest="bump",
        action="store_const",
        const="major",
        help="Bump the major version (e.g. 1.2.3 -> 2.0.0).",
    )
    bump_group.add_argument(
        "--minor",
        dest="bump",
        action="store_const",
        const="minor",
        help="Bump the minor version (e.g. 1.2.3 -> 1.3.0).",
    )
    bump_group.add_argument(
        "--patch",
        dest="bump",
        action="store_const",
        const="patch",
        help="Bump the patch version (e.g. 1.2.3 -> 1.2.4) [default].",
    )
    build_p.set_defaults(func=cmd_build, bump="patch")

    # status
    status_p = sub.add_parser(
        "status",
        help="Show current version and pending changes.",
    )
    status_p.set_defaults(func=cmd_status)

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(0)

    args.func(args)


if __name__ == "__main__":
    main()
