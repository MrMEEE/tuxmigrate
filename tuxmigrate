def cmd_remove(args: argparse.Namespace) -> None:
    """Remove a version or a specific playbook from the role, moving files back to changes/."""
    data = load_versions()
    assert data is not None

    playbooks: list[str] = data.get("playbooks", [])
    playbooks_path = Path(ROLE_PLAYBOOKS_DIR)
    changes_path = Path(CHANGES_DIR)
    changes_path.mkdir(exist_ok=True)

    if args.playbook:
        # Remove a single named playbook (match by original name or full stored name).
        target = args.playbook
        matched = [p for p in playbooks if p == target or p.endswith(f"_{target}")]
        if not matched:
            die(f"No playbook matching '{target}' found in the role.\n"
                f"Stored playbooks: {', '.join(playbooks) or '(none)'}")
        if len(matched) > 1:
            die(f"Ambiguous match for '{target}': {', '.join(matched)}\n"
                f"Use the full stored filename.")
        stored_name = matched[0]
        src = playbooks_path / stored_name
        # Restore to changes/ using the original filename (strip version prefix).
        original = "_".join(stored_name.split("_")[2:])  # strip "VERSION_NN_"
        dest = changes_path / original
        if src.exists():
            shutil.move(str(src), str(dest))
            print(f"Moved: role/playbooks/{stored_name} -> {CHANGES_DIR}/{original}")
        else:
            print(f"WARNING: {src} not found on disk — removing from registry only.", file=sys.stderr)
        playbooks.remove(stored_name)

    elif args.version:
        ver = args.version
        to_remove = [p for p in playbooks if p.startswith(f"{ver}_")]
        if not to_remove:
            die(f"No playbooks found for version '{ver}'.\n"
                f"Stored playbooks: {', '.join(playbooks) or '(none)'}")
        print(f"Removing {len(to_remove)} playbook(s) for version {ver}:")
        for stored_name in to_remove:
            src = playbooks_path / stored_name
            original = "_".join(stored_name.split("_")[2:])
            dest = changes_path / original
            if src.exists():
                shutil.move(str(src), str(dest))
                print(f"  Moved: role/playbooks/{stored_name} -> {CHANGES_DIR}/{original}")
            else:
                print(f"  WARNING: {src} not found on disk — removing from registry only.", file=sys.stderr)
            playbooks.remove(stored_name)

    else:
        die("Specify --version VERSION or --playbook PLAYBOOK_NAME.")

    data["playbooks"] = playbooks
    save_versions(data)

    tasks_file = Path(ROLE_TASKS_DIR) / "main.yml"
    tasks_file.write_text(generate_tasks_main(playbooks))
    print(f"Regenerated {tasks_file}")


# ---------------------------------------------------------------------------
# Lint venv helpers
# ---------------------------------------------------------------------------

def _lint_venv_python() -> Path:
    """Return the python executable inside the lint venv."""
    return Path(LINT_VENV_DIR) / "bin" / "python"


def _ensure_lint_venv() -> None:
    """Create the lint venv and install ansible-lint if not already present."""
    venv_python = _lint_venv_python()
    if not venv_python.exists():
        print(f"Creating lint venv in '{LINT_VENV_DIR}' (first build)...")
        if subprocess.run([sys.executable, "-m", "venv", LINT_VENV_DIR]).returncode != 0:
            die("Failed to create lint venv.")
    # Check whether ansible-lint is installed.
    check = subprocess.run(
        [str(venv_python), "-m", "pip", "show", "ansible-lint"],
        capture_output=True,
    )
    if check.returncode != 0:
        print("Installing ansible-lint into lint venv...")
        pip = Path(LINT_VENV_DIR) / "bin" / "pip"
        if subprocess.run([str(pip), "install", "--quiet", "ansible-lint"]).returncode != 0:
            die("Failed to install ansible-lint.")


def _lint_files(files: list[Path]) -> bool:
    """Run ansible-lint on *files*. Returns True if all pass."""
    lint_bin = Path(LINT_VENV_DIR) / "bin" / "ansible-lint"
    cmd = [str(lint_bin), "--nocolor", "--"] + [str(f) for f in files]
    print(f"\nLinting {len(files)} file(s) with ansible-lint...")
    result = subprocess.run(cmd)
    return result.returncode == 0


def cmd_build(args: argparse.Namespace) -> None:
    """Increment version, absorb changes into role, rebuild RPM."""

    # 1. Discover pending change files
    changes_path = Path(CHANGES_DIR)
    pending = sorted(
        p for p in changes_path.iterdir()
        if p.suffix in {".yml", ".yaml"} and p.is_file()
    )

    if not pending:
        die(
            f"No YAML task files found in '{CHANGES_DIR}/'. "
            "Add at least one task file before building."
        )

    print(f"Found {len(pending)} pending change(s):")
    for p in pending:
        print(f"  {p.name}")

    # 2. Lint all pending files before touching anything.
    _ensure_lint_venv()
    if not _lint_files(pending):
        die("ansible-lint reported errors. Fix them before building.")

    # 3. Load state
    data = load_versions()
    # ensure_config() already ran in main(), so data is guaranteed to exist
    assert data is not None

    # 3. Resolve build metadata early (CLI flag > versions.json > hardcoded default)
    #    so we can validate and check tool availability before touching any files.
    package_name = args.package_name or data.get("package_name", "tuxmigrate")
    maintainer   = args.maintainer   or data.get("maintainer",   "tuxmigrate")
    description  = args.description  or data.get("description",  "TuxMigrate configuration management")
    build_tool   = args.build_tool   or data.get("build_tool",   "fpm")

    if build_tool not in SUPPORTED_BUILD_TOOLS:
        die(f"Unknown build_tool '{build_tool}' in {VERSIONS_FILE}. Choose from: {', '.join(SUPPORTED_BUILD_TOOLS)}.")

    # 4. Ensure the build tool binary is present.
    if build_tool == "rpmbuild" and not shutil.which("rpmbuild"):
        answer = input("'rpmbuild' not found. Install rpm-build via dnf? [Y/n]: ").strip().lower()
        if answer in ("", "y", "yes"):
            if subprocess.run(["dnf", "-y", "install", "rpm-build"]).returncode != 0:
                die("Failed to install rpm-build.")
        else:
            die("rpmbuild not found. Install rpm-build and try again.")

    # 5. Bump version (save old state for rollback)
    old_version   = data["version"]
    old_playbooks = list(data.get("playbooks", []))
    new_version   = increment_version(old_version, args.bump)
    print(f"Bumping version ({args.bump}): {old_version} -> {new_version}")

    # 6. Move and rename change files into the role
    playbooks_path = Path(ROLE_PLAYBOOKS_DIR)
    playbooks_path.mkdir(parents=True, exist_ok=True)

    new_entries: list[str] = []
    for idx, src in enumerate(pending, start=1):
        dest_name = f"{new_version}_{idx:02d}_{src.name}"
        dest = playbooks_path / dest_name
        shutil.move(str(src), str(dest))
        new_entries.append(dest_name)
        print(f"  Moved: {src.name} -> role/playbooks/{dest_name}")

    # 7. Update versions.json
    data["version"]      = new_version
    data["package_name"] = package_name
    data["maintainer"]   = maintainer
    data["description"]  = description
    data["build_tool"]   = build_tool
    data.setdefault("playbooks", []).extend(new_entries)
    save_versions(data)

    # 8. Regenerate role/tasks/main.yml
    tasks_path = Path(ROLE_TASKS_DIR)
    tasks_path.mkdir(parents=True, exist_ok=True)
    tasks_content = generate_tasks_main(data["playbooks"])
    tasks_file = tasks_path / "main.yml"
    tasks_file.write_text(tasks_content)
    print(f"\nRegenerated {tasks_file}")

    # 9. Build the RPM; roll back everything on failure.
    if build_tool == "fpm":
        success = _build_fpm(package_name, new_version, maintainer, description)
    else:
        success = _build_rpmbuild(package_name, new_version, maintainer, description)

    if not success:
        print("\nBuild failed — rolling back changes...", file=sys.stderr)
        for src, dest_name in zip(pending, new_entries):
            dest = playbooks_path / dest_name
            if dest.exists():
                shutil.move(str(dest), str(src))
                print(f"  Restored: {dest_name} -> {CHANGES_DIR}/{src.name}")
        data["version"]   = old_version
        data["playbooks"] = old_playbooks
        save_versions(data)
        tasks_file.write_text(generate_tasks_main(old_playbooks))
        print(f"  Restored {tasks_file}")
        die("Build failed. All changes have been rolled back to the changes/ folder.")

    # 10. Push to Katello/Satellite if configured
    katello_cfg = data.get("katello", {})
    if katello_cfg.get("enabled"):
        katello_cfg = _kat_repair_config(data)
        output_dir = _rpm_output_dir(package_name)
        rpm_file = str(
            output_dir / (
                f"{package_name}-{new_version}-1.x86_64.rpm"
                if build_tool == "fpm"
                else f"{package_name}-{new_version}-1.noarch.rpm"
            )
        )
        _push_katello(rpm_file, katello_cfg)


def cmd_rebuild(args: argparse.Namespace) -> None:
    """Re-run the RPM build for a specific already-released version.

    Does NOT bump the version or move any files — it simply re-invokes the
    build tool using the metadata that was saved at build time.
    """
    data = load_versions()
    assert data is not None

    package_name = data.get("package_name", "tuxmigrate")
    maintainer   = data.get("maintainer",   "tuxmigrate")
    description  = data.get("description",  "TuxMigrate configuration management")
    build_tool   = data.get("build_tool",   "fpm")
    version      = args.version

    # Verify the version exists in recorded history
    all_playbooks = data.get("playbooks", [])
    version_playbooks = [p for p in all_playbooks if p.startswith(f"{version}_")]
    if not version_playbooks:
        # The current version has no prefix — check if it matches exactly
        if data["version"] != version:
            die(
                f"Version {version} not found in {VERSIONS_FILE}.\n"
                f"Current version is {data['version']}. "
                f"Use 'tuxmigrate status' to see recorded playbooks."
            )

    if build_tool not in SUPPORTED_BUILD_TOOLS:
        die(f"Unknown build_tool '{build_tool}'. Choose from: {', '.join(SUPPORTED_BUILD_TOOLS)}.")

    # Ensure rpmbuild is available if needed
    if build_tool == "rpmbuild" and not shutil.which("rpmbuild"):
        answer = input("'rpmbuild' not found. Install rpm-build via dnf? [Y/n]: ").strip().lower()
        if answer in ("", "y", "yes"):
            if subprocess.run(["dnf", "-y", "install", "rpm-build"]).returncode != 0:
                die("Failed to install rpm-build.")
        else:
            die("rpmbuild not found. Install rpm-build and try again.")

    print(f"Rebuilding RPM for version {version} (build tool: {build_tool})...")

    if build_tool == "fpm":
        success = _build_fpm(package_name, version, maintainer, description)
    else:
        success = _build_rpmbuild(package_name, version, maintainer, description)

    if not success:
        die("Rebuild failed. Check the output above for details.")

    if args.upload:
        katello_cfg = data.get("katello", {})
        if not katello_cfg.get("enabled"):
            print("WARNING: Katello is not enabled; skipping upload.", file=sys.stderr)
        else:
            katello_cfg = _kat_repair_config(data)
            output_dir = _rpm_output_dir(package_name)
            rpm_name = (
                f"{package_name}-{version}-1.x86_64.rpm"
                if build_tool == "fpm"
                else f"{package_name}-{version}-1.noarch.rpm"
            )
            _push_katello(str(output_dir / rpm_name), katello_cfg)


def cmd_upload(args: argparse.Namespace) -> None:
    """Upload the RPM for a specific version to Katello without rebuilding."""
    data = load_versions()
    assert data is not None
    katello_cfg = data.get("katello", {})
    if not katello_cfg.get("enabled"):
        die("Katello integration is not enabled. Run 'tuxmigrate status' for details.")

    package_name = data.get("package_name", "tuxmigrate")
    build_tool   = data.get("build_tool", "fpm")
    version      = args.version

    katello_cfg = _kat_repair_config(data)

    output_dir = _rpm_output_dir(package_name)
    rpm_name = (
        f"{package_name}-{version}-1.x86_64.rpm"
        if build_tool == "fpm"
        else f"{package_name}-{version}-1.noarch.rpm"
    )
    rpm_file = output_dir / rpm_name

    if not rpm_file.exists():
        # Also check root directory for RPMs built before the subdirectory change
        fallback = Path(rpm_name)
        if fallback.exists():
            print(f"Found RPM in current directory (pre-subdirectory build): {fallback}")
            rpm_file = fallback
        else:
            die(
                f"RPM not found: {rpm_file}\n"
                f"Run 'tuxmigrate build' to produce the RPM first."
            )

    _push_katello(str(rpm_file), katello_cfg)


def cmd_status(args: argparse.Namespace) -> None:
    """Show current version and registered playbooks."""
    data = load_versions()
    # ensure_config() already ran in main(), so data is guaranteed to exist
    assert data is not None
    print(f"Package    : {data.get('package_name', 'tuxmigrate')}")
    print(f"Version    : {data['version']}")
    print(f"Build tool : {data.get('build_tool', 'fpm')}")
    katello = data.get("katello", {})
    if katello.get("enabled"):
        print(f"Katello URL: {katello.get('url')}")
        print(f"  Org      : {katello.get('organization')}")
        print(f"  Product  : {katello.get('product')}")
        print(f"  Repo     : {katello.get('repository')}")
        print(f"  SSL      : {'verify' if katello.get('ssl_verify', True) else 'skip verify'}")
        has_token = bool(katello.get("token") or os.environ.get("KATELLO_TOKEN"))
        print(f"  Auth     : Personal Access Token ({'stored' if has_token else 'will prompt at build'})")
    else:
        print("Katello    : disabled")
    playbooks = data.get("playbooks", [])
    if not playbooks:
        print("Playbooks: (none yet)")
    else:
        print(f"Playbooks ({len(playbooks)}):")
        for pb in playbooks:
            print(f"  {pb}")

    changes_path = Path(CHANGES_DIR)
    pending = sorted(
        p.name
        for p in changes_path.iterdir()
        if p.suffix in {".yml", ".yaml"} and p.is_file()
    )
    if pending:
        print(f"\nPending changes ({len(pending)}) - ready for next build:")
        for name in pending:
            print(f"  {name}")
    else:
        print("\nNo pending changes.")


