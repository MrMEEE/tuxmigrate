def die(msg: str) -> None:
    print(f"ERROR: {msg}", file=sys.stderr)
    sys.exit(1)


SUPPORTED_BUILD_TOOLS = ("fpm", "rpmbuild")


def prompt_field(label: str, cli_value: str | None, default: str) -> str:
    """Return cli_value if provided, otherwise prompt the user interactively."""
    if cli_value:
        return cli_value
    answer = input(f"  {label} [{default}]: ").strip()
    return answer if answer else default


def prompt_choice(label: str, cli_value: str | None, choices: tuple, default: str) -> str:
    """Prompt for a value that must be one of *choices*."""
    if cli_value:
        if cli_value not in choices:
            die(f"Invalid {label} '{cli_value}'. Choose from: {', '.join(choices)}.")
        return cli_value
    while True:
        answer = input(f"  {label} {list(choices)} [{default}]: ").strip()
        value = answer if answer else default
        if value in choices:
            return value
        print(f"    Please enter one of: {', '.join(choices)}")


def load_versions() -> dict | None:
    """Load versions.json. Returns None if the file does not exist yet."""
    if not Path(VERSIONS_FILE).exists():
        return None
    with open(VERSIONS_FILE) as fh:
        return json.load(fh)


def save_versions(data: dict) -> None:
    with open(VERSIONS_FILE, "w") as fh:
        json.dump(data, fh, indent=2)
        fh.write("\n")


def ensure_config(args: argparse.Namespace) -> None:
    """Run the interactive first-time setup if versions.json does not exist yet."""
    if Path(VERSIONS_FILE).exists():
        return
    print(f"{VERSIONS_FILE} not found — initialising new project.")
    print("Press Enter to accept the [default] or type a new value.\n")
    package_name = prompt_field("Package name", getattr(args, 'package_name', None), "tuxmigrate")
    maintainer   = prompt_field("Maintainer",   getattr(args, 'maintainer',   None), "tuxmigrate")
    description  = prompt_field("Description",  getattr(args, 'description',  None), "TuxMigrate configuration management")
    build_tool   = prompt_choice("Build tool",   getattr(args, 'build_tool',   None), SUPPORTED_BUILD_TOOLS, "fpm")

    # --- Katello / Satellite ---
    print("\n--- Katello / Satellite integration ---")
    use_katello = input("  Push RPMs to Katello/Satellite? [y/N]: ").strip().lower()
    katello: dict = {"enabled": False}
    if use_katello in ("y", "yes"):
        kat_url       = prompt_field("Satellite URL", None, "https://satellite.example.com")
        ssl_ans       = input("  Verify SSL certificate? [Y/n]: ").strip().lower()
        kat_ssl       = ssl_ans not in ("n", "no")
        print("  Admin credentials (used for setup only — never saved):")
        kat_admin_user = prompt_field("Admin username", None, "admin")
        kat_admin_pass = getpass.getpass("  Admin password: ")
        admin_auth    = _kat_admin_auth(kat_admin_user, kat_admin_pass)

        print("  Testing admin connection...")
        _, conn_err = _kat_get(kat_url, admin_auth, "/api/v2/ping", verify_ssl=kat_ssl)
        if conn_err:
            print(f"  Connection failed: {conn_err}", file=sys.stderr)
            cont = input("  Continue anyway? [y/N]: ").strip().lower()
            if cont not in ("y", "yes"):
                print("  Katello integration disabled.")
                use_katello = ""
        else:
            print("  Connection OK.")

        if use_katello in ("y", "yes"):
            svc_login = package_name
            print(f"\n  Creating service account '{svc_login}'...")
            user_id, err = _kat_create_service_account(kat_url, admin_auth, svc_login, kat_ssl)
            if err:
                die(f"Failed to create Katello service account: {err}")

            role_name = f"tuxmigrate-{svc_login}"
            print(f"  Creating role '{role_name}'...")
            role_id, err = _kat_create_role(kat_url, admin_auth, role_name, kat_ssl)
            if err:
                die(f"Failed to create Katello role: {err}")

            perm_names = [
                "view_organizations",
                "view_products",
                "edit_products",
                "view_repositories",
                "upload_to_repositories",
            ]
            print("  Looking up and assigning minimal permissions...")
            perms = _kat_find_permission_ids(kat_url, admin_auth, perm_names, kat_ssl)
            err = _kat_create_filter(kat_url, admin_auth, role_id, perms, kat_ssl)
            if err:
                print(f"  WARNING: Could not set permissions on role: {err}", file=sys.stderr)
            err = _kat_assign_role_to_user(kat_url, admin_auth, user_id, role_id, kat_ssl)
            if err:
                print(f"  WARNING: Could not assign role to user: {err}", file=sys.stderr)

            token_name = f"tuxmigrate-{svc_login}"
            print(f"  Creating Personal Access Token '{token_name}'...")
            kat_token, err = _kat_create_pat(kat_url, admin_auth, user_id, token_name, kat_ssl)
            if err:
                die(f"Failed to create Personal Access Token: {err}")
            if not kat_token:
                die("Personal Access Token was created but Satellite did not return the token value.")
            print(f"  Token created and stored in {VERSIONS_FILE} (git-ignored).")
            print("  KATELLO_TOKEN env var overrides the stored token at build time.\n")

            # Foreman PATs authenticate with Basic auth (login:token_value), not Bearer.
            kat_pat_auth = _kat_admin_auth(svc_login, kat_token)

            # Use the new service account token to select org / product / repo
            orgs = _kat_api_list(kat_url, kat_pat_auth, "/api/v2/organizations", verify_ssl=kat_ssl)
            kat_org = _kat_pick("Organization", orgs, "Default Organization")

            org_id = next((o["id"] for o in orgs if o["name"] == kat_org), None)
            prod_path = (
                f"/katello/api/organizations/{org_id}/products"
                if org_id else "/katello/api/products"
            )
            prods = _kat_api_list(kat_url, kat_pat_auth, prod_path, verify_ssl=kat_ssl)
            kat_prod = _kat_pick("Product", prods, "Custom RPMs")

            prod_id = next((p["id"] for p in prods if p["name"] == kat_prod), None)
            repo_path = (
                f"/katello/api/products/{prod_id}/repositories"
                if prod_id else "/katello/api/repositories"
            )
            repos = _kat_api_list(kat_url, kat_pat_auth, repo_path, verify_ssl=kat_ssl)
            kat_repo = _kat_pick("Repository", repos, package_name)
            repo_id = next((r["id"] for r in repos if r["name"] == kat_repo), None)

            katello = {
                "enabled":       True,
                "url":           kat_url,
                "organization":  kat_org,
                "product":       kat_prod,
                "repository":    kat_repo,
                "repository_id": repo_id,
                "login":         svc_login,
                "ssl_verify":    kat_ssl,
                "token":         kat_token,
            }

    data = {
        "version": "1.0.0",
        "package_name": package_name,
        "maintainer": maintainer,
        "description": description,
        "build_tool": build_tool,
        "playbooks": [],
        "katello": katello,
    }
    save_versions(data)
    print(f"\nCreated {VERSIONS_FILE} (version 1.0.0)\n")


def increment_version(version: str, bump: str = "minor") -> str:
    """Return a new version string with the requested component bumped.

    bump values:
      'major' - increment major, reset minor and patch to 0
      'minor' - increment minor, reset patch to 0  (default)
      'patch' - increment patch only
    """
    parts = version.split(".")
    if len(parts) != 3:
        die(f"Version '{version}' is not in MAJOR.MINOR.PATCH format.")
    major, minor, patch = (int(p) for p in parts)
    if bump == "major":
        return f"{major + 1}.0.0"
    elif bump == "minor":
        return f"{major}.{minor + 1}.0"
    elif bump == "patch":
        return f"{major}.{minor}.{patch + 1}"
    else:
        die(f"Unknown bump type '{bump}'. Use major, minor, or patch.")


def sanitize(name: str) -> str:
    """Replace any non-alphanumeric character with underscore."""
    return re.sub(r"[^a-zA-Z0-9]", "_", name)


def fact_name(playbook_filename: str) -> str:
    """Return the Ansible local fact name derived from a playbook filename.

    e.g. '1.2.0_01_install_vim.yml' -> 'tuxmigrate_1_2_0_01_install_vim'
    """
    stem = Path(playbook_filename).stem
    return f"tuxmigrate_{sanitize(stem)}"


def register_var(playbook_filename: str) -> str:
    """Return a unique Ansible register variable name for a playbook."""
    return f"_tm_fact_{sanitize(Path(playbook_filename).stem)}"


# ---------------------------------------------------------------------------
# Role task generation
# ---------------------------------------------------------------------------


def generate_tasks_main(playbooks: list[str]) -> str:
    """Generate the content of role/tasks/main.yml for the given ordered list
    of playbook filenames."""
    lines = [
        "---",
        "# Auto-generated by tuxmigrate - do not edit manually.",
        "# Re-run 'tuxmigrate build' to update.",
        "",
        "- name: Ensure facts directory exists",
        "  ansible.builtin.file:",
        f"    path: {FACTS_DIR}",
        "    state: directory",
        "    mode: '0755'",
        "",
    ]

    for pb in playbooks:
        fname = fact_name(pb)
        reg = register_var(pb)
        fact_path = f"{FACTS_DIR}/{fname}.fact"

        lines += [
            f"# --- {pb} ---",
            f"- name: Check whether '{pb}' has already been applied",
            f"  ansible.builtin.stat:",
            f"    path: {fact_path}",
            f"  register: {reg}",
            "",
            f"- name: Apply changes from '{pb}'",
            f"  ansible.builtin.include_tasks:",
            f"    file: playbooks/{pb}",
            f"  when: not {reg}.stat.exists",
            "",
            f"- name: Record '{pb}' as applied",
            f"  ansible.builtin.copy:",
            f'    content: |',
            f'      {{"applied": true, "playbook": "{pb}"}}',
            f"    dest: {fact_path}",
            f"    mode: '0644'",
            f"  when: not {reg}.stat.exists",
            "",
        ]

    return "\n".join(lines)


