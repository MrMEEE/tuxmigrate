def _rpm_role_path(package_name: str) -> str:
    return f"/usr/share/{package_name}/role"


def _rpm_site_yml_path(package_name: str) -> str:
    return f"/usr/share/{package_name}/site.yml"


def _rpm_output_dir(package_name: str) -> Path:
    """Local directory where built RPMs are stored: ./<package_name>-rpms/"""
    return Path(f"{package_name}-rpms")


def _print_install_hint(rpm_file: str) -> None:
    print(f"\nBuild complete: {rpm_file}")
    print(
        f"Install with:  sudo rpm -Uvh {rpm_file}\n"
        f"               or: sudo dnf install ./{rpm_file}"
    )


# ---------------------------------------------------------------------------
# Katello / Satellite helpers
# ---------------------------------------------------------------------------


def _kat_ssl_ctx(verify_ssl: bool) -> ssl.SSLContext:
    ctx = ssl.create_default_context()
    if not verify_ssl:
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
    return ctx


def _kat_admin_auth(admin_user: str, admin_pass: str) -> str:
    """Return a Basic auth header value for admin username/password."""
    return "Basic " + base64.b64encode(f"{admin_user}:{admin_pass}".encode()).decode()


def _kat_request(
    url: str, auth: str, method: str, path: str,
    payload: dict | None = None, verify_ssl: bool = True,
) -> tuple[dict | None, str]:
    """Generic Satellite/Katello API call. Returns (body_dict_or_None, error_str)."""
    full_url = url.rstrip("/") + path
    data = json.dumps(payload).encode() if payload is not None else None
    req = urllib.request.Request(full_url, data=data, method=method)
    req.add_header("Authorization", auth)
    req.add_header("Content-Type", "application/json")
    req.add_header("Accept", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=30, context=_kat_ssl_ctx(verify_ssl)) as resp:
            body = resp.read().decode()
            return json.loads(body) if body else {}, ""
    except urllib.error.HTTPError as exc:
        try:
            detail = exc.read().decode()
        except Exception:
            detail = ""
        return None, f"HTTP {exc.code}: {detail}"
    except Exception as exc:  # noqa: BLE001
        return None, str(exc)


def _kat_get(url: str, auth: str, path: str, verify_ssl: bool = True) -> tuple[dict | None, str]:
    return _kat_request(url, auth, "GET", path, verify_ssl=verify_ssl)


def _kat_post(
    url: str, auth: str, path: str, payload: dict, verify_ssl: bool = True,
) -> tuple[dict | None, str]:
    return _kat_request(url, auth, "POST", path, payload, verify_ssl)


def _kat_create_service_account(
    url: str, admin_auth: str, login: str, verify_ssl: bool = True,
) -> tuple[int | None, str]:
    """Create a local Foreman user for tuxmigrate. Returns (user_id, error)."""
    password = "".join(
        secrets.choice(string.ascii_letters + string.digits + "!@#$%^&*")
        for _ in range(32)
    )
    payload = {
        "user": {
            "login":          login,
            "firstname":      "TuxMigrate",
            "lastname":       "Service",
            "mail":           f"{login}@localhost.invalid",
            "password":       password,
            "auth_source_id": 1,   # 1 = internal database
            "admin":          False,
        }
    }
    result, err = _kat_post(url, admin_auth, "/api/v2/users", payload, verify_ssl)
    if err:
        if "already" in err:
            search = urllib.parse.quote(f"login = {login}")
            found, ferr = _kat_get(url, admin_auth, f"/api/v2/users?search={search}&per_page=2", verify_ssl)
            if not ferr and found and found.get("results"):
                uid = found["results"][0]["id"]
                print(f"    (service account '{login}' already exists, reusing id={uid})")
                return uid, ""
        return None, err
    return result["id"], ""


def _kat_create_role(
    url: str, admin_auth: str, role_name: str, verify_ssl: bool = True,
) -> tuple[int | None, str]:
    """Create a custom Foreman role. Returns (role_id, error)."""
    payload = {"role": {"name": role_name, "description": "Auto-created by tuxmigrate"}}
    result, err = _kat_post(url, admin_auth, "/api/v2/roles", payload, verify_ssl)
    if err:
        if "already" in err:
            search = urllib.parse.quote(f"name = {role_name}")
            found, ferr = _kat_get(url, admin_auth, f"/api/v2/roles?search={search}&per_page=2", verify_ssl)
            if not ferr and found and found.get("results"):
                rid = found["results"][0]["id"]
                print(f"    (role '{role_name}' already exists, reusing id={rid})")
                return rid, ""
        return None, err
    return result["id"], ""


def _kat_find_permission_ids(
    url: str, admin_auth: str, names: list[str], verify_ssl: bool = True,
) -> list[dict]:
    """Return Foreman permissions (id + resource_type) for the given permission names."""
    perms: list[dict] = []
    for name in names:
        path = "/api/v2/permissions?search=" + urllib.parse.quote(f"name = {name}") + "&per_page=5"
        result, err = _kat_get(url, admin_auth, path, verify_ssl)
        if err:
            print(f"    WARNING: could not look up permission '{name}': {err}", file=sys.stderr)
        elif result and result.get("results"):
            p = result["results"][0]
            perms.append({"id": p["id"], "resource_type": p.get("resource_type") or ""})
    return perms


def _kat_create_filter(
    url: str, admin_auth: str, role_id: int, permissions: list[dict], verify_ssl: bool = True,
) -> str:
    """Attach permissions to a role. Groups by resource_type (Foreman requirement).
    Returns concatenated error string or empty."""
    groups: dict[str, list[int]] = {}
    for p in permissions:
        groups.setdefault(p["resource_type"], []).append(p["id"])
    errors: list[str] = []
    for rtype, ids in groups.items():
        payload = {
            "filter": {
                "role_id":        role_id,
                "permission_ids": ids,
                "unlimited":      True,
            }
        }
        _, err = _kat_post(url, admin_auth, "/api/v2/filters", payload, verify_ssl)
        if err:
            errors.append(f"{rtype}: {err}")
    return "; ".join(errors)


def _kat_assign_role_to_user(
    url: str, admin_auth: str, user_id: int, role_id: int, verify_ssl: bool = True,
) -> str:
    """Assign a role to a user via PATCH. Returns error string or empty."""
    _, err = _kat_request(
        url, admin_auth, "PATCH",
        f"/api/v2/users/{user_id}",
        {"user": {"role_ids": [role_id]}},
        verify_ssl,
    )
    return err


def _kat_create_pat(
    url: str, admin_auth: str, user_id: int, token_name: str, verify_ssl: bool = True,
) -> tuple[str | None, str]:
    """Create a Personal Access Token for a user. Returns (token_value, error)."""
    path = f"/api/v2/users/{user_id}/personal_access_tokens"
    payload = {"personal_access_token": {"name": token_name}}
    result, err = _kat_post(url, admin_auth, path, payload, verify_ssl)
    if err:
        if "already" in err:
            # Delete the existing PAT with this name and recreate to capture the token value.
            list_result, list_err = _kat_get(url, admin_auth, path + "?per_page=200", verify_ssl)
            if list_err:
                return None, f"PAT already exists and could not list existing PATs: {list_err}"
            # Foreman may return {"results": [...]} or a bare list.
            pats = (
                list_result.get("results", []) if isinstance(list_result, dict)
                else list_result or []
            )
            pat_id = next((p["id"] for p in pats if p.get("name") == token_name), None)
            if pat_id is None:
                return None, f"PAT '{token_name}' reported as taken but was not found in list"
            _, del_err = _kat_request(url, admin_auth, "DELETE",
                                      f"{path}/{pat_id}", verify_ssl=verify_ssl)
            if del_err:
                print(f"    WARNING: DELETE returned error: {del_err}", file=sys.stderr)
            # Wait up to 6 s for deletion to propagate.
            deleted = False
            for _ in range(6):
                time.sleep(1)
                check, _ = _kat_get(url, admin_auth, path + "?per_page=200", verify_ssl)
                check_pats = (
                    check.get("results", []) if isinstance(check, dict) else check or []
                ) if check else []
                if not any(p.get("name") == token_name for p in check_pats):
                    deleted = True
                    break
            if deleted:
                result, err = _kat_post(url, admin_auth, path, payload, verify_ssl)
            else:
                # Satellite did not remove the PAT — fall back to a unique name.
                unique_name = token_name + "-" + secrets.token_hex(4)
                print(f"    (old PAT could not be removed; creating '{unique_name}' instead)",
                      file=sys.stderr)
                result, err = _kat_post(
                    url, admin_auth, path,
                    {"personal_access_token": {"name": unique_name}},
                    verify_ssl,
                )
        if err:
            return None, err
    token_val = result.get("token_value") or result.get("value") or result.get("token", "")
    return token_val or None, ""


def _kat_api_list(url: str, auth: str, path: str, verify_ssl: bool = True) -> list[dict]:
    """Fetch a Katello API list using the given auth header value. Returns [] on failure."""
    result, err = _kat_get(url, auth, path + "?per_page=200", verify_ssl)
    if err:
        print(f"    WARNING: could not fetch {path}: {err}", file=sys.stderr)
        return []
    if result is None:
        return []
    return result.get("results", result) if isinstance(result, dict) else result


def _kat_pick(label: str, items: list[dict], default: str) -> str:
    """Present a numbered list of Satellite items and return the chosen name.
    Falls back to free-text entry if the list is empty.
    """
    if not items:
        answer = input(f"  {label} (could not fetch list) [{default}]: ").strip()
        return answer if answer else default
    print(f"\n  Available {label}s:")
    for i, item in enumerate(items, start=1):
        print(f"    {i}) {item['name']}")
    while True:
        raw = input(f"  Select {label} [1-{len(items)}] or type a name: ").strip()
        if not raw:
            return default
        if raw.isdigit():
            idx = int(raw) - 1
            if 0 <= idx < len(items):
                return items[idx]["name"]
            print(f"    Please enter a number between 1 and {len(items)}.")
        else:
            return raw


def _katello_token(katello_cfg: dict) -> str:
    """Return the Katello Personal Access Token.

    Precedence: KATELLO_TOKEN env var > token stored in versions.json > interactive prompt.
    """
    token = os.environ.get("KATELLO_TOKEN", "") or katello_cfg.get("token", "")
    if not token:
        token = input(f"  Katello Personal Access Token for {katello_cfg['url']}: ").strip()
    return token


def _kat_repair_config(data: dict) -> dict:
    """Fill in missing 'login' and 'repository_id' fields in the katello config block.

    Handles versions.json files created before those fields were introduced.
    Derives 'login' from 'package_name' (the historical convention) and looks
    up 'repository_id' via the Katello API when it is absent.
    Saves the repaired values back to versions.json so the lookup only happens once.
    Returns the (possibly updated) katello sub-dict.
    """
    katello = data.get("katello", {})
    if not katello.get("enabled"):
        return katello

    changed = False
    package_name = data.get("package_name", "tuxmigrate")

    # Derive login from package_name if absent (always been the convention).
    if not katello.get("login"):
        katello["login"] = package_name
        changed = True
        print(f"  (auto-set katello login = '{package_name}' from package_name)")

    # Look up repository_id from the API if absent.
    if not katello.get("repository_id"):
        url        = katello.get("url", "")
        verify_ssl = katello.get("ssl_verify", True)
        login      = katello["login"]
        token      = _katello_token(katello)
        auth       = _kat_admin_auth(login, token)

        org_name  = katello.get("organization", "")
        prod_name = katello.get("product", "")
        repo_name = katello.get("repository", "")

        # Resolve org_id
        orgs = _kat_api_list(url, auth, "/api/v2/organizations", verify_ssl)
        org_id = next((o["id"] for o in orgs if o["name"] == org_name), None)

        # Resolve prod_id
        prod_path = (
            f"/katello/api/organizations/{org_id}/products"
            if org_id else "/katello/api/products"
        )
        prods = _kat_api_list(url, auth, prod_path, verify_ssl)
        prod_id = next((p["id"] for p in prods if p["name"] == prod_name), None)

        # Resolve repo_id
        repo_path = (
            f"/katello/api/products/{prod_id}/repositories"
            if prod_id else "/katello/api/repositories"
        )
        repos = _kat_api_list(url, auth, repo_path, verify_ssl)
        repo_id = next((r["id"] for r in repos if r["name"] == repo_name), None)

        if repo_id:
            katello["repository_id"] = repo_id
            changed = True
            print(f"  (auto-resolved katello repository_id = {repo_id} for '{repo_name}')")
        else:
            print(
                f"WARNING: could not resolve repository_id for '{repo_name}' — "
                "upload may fail.",
                file=sys.stderr,
            )

    if changed:
        data["katello"] = katello
        save_versions(data)

    # Repair role permissions if edit_products was missing (added in a later release).
    # Tracked by 'permissions_v2' flag to avoid prompting for admin creds repeatedly.
    if not katello.get("permissions_v2"):
        url        = katello.get("url", "")
        verify_ssl = katello.get("ssl_verify", True)
        login      = katello.get("login", "")
        token      = _katello_token(katello)
        auth       = _kat_admin_auth(login, token)
        role_name  = f"tuxmigrate-{login}"

        # Check whether the service account already has edit_products.
        # We look for the permission in the role's filter list.
        role_search = urllib.parse.quote(f"name = {role_name}")
        found, _ = _kat_get(url, auth, f"/api/v2/roles?search={role_search}&per_page=2", verify_ssl)
        role_id = None
        if found and found.get("results"):
            role_id = found["results"][0]["id"]

        needs_repair = False
        if role_id:
            filters_result, _ = _kat_get(url, auth, f"/api/v2/roles/{role_id}/filters?per_page=200", verify_ssl)
            existing_perms: set[str] = set()
            if filters_result and filters_result.get("results"):
                for f in filters_result["results"]:
                    for p in f.get("permissions", []):
                        existing_perms.add(p.get("name", ""))
            needs_repair = "edit_products" not in existing_perms
        else:
            # Can't look up the role with service account token — assume repair needed.
            needs_repair = True

        if needs_repair:
            print(
                "  NOTE: The Katello service account role is missing 'edit_products' "
                "(required for RPM upload).\n"
                "  Admin credentials are needed once to add this permission."
            )
            kat_admin_user = input("  Admin username [admin]: ").strip() or "admin"
            kat_admin_pass = getpass.getpass("  Admin password: ")
            admin_auth = _kat_admin_auth(kat_admin_user, kat_admin_pass)

            # Re-resolve role_id with admin auth if needed.
            if not role_id:
                found, _ = _kat_get(url, admin_auth, f"/api/v2/roles?search={role_search}&per_page=2", verify_ssl)
                if found and found.get("results"):
                    role_id = found["results"][0]["id"]

            if role_id:
                perms = _kat_find_permission_ids(url, admin_auth, ["edit_products"], verify_ssl)
                err = _kat_create_filter(url, admin_auth, role_id, perms, verify_ssl)
                if err:
                    print(f"  WARNING: Could not add edit_products permission: {err}", file=sys.stderr)
                else:
                    print("  Added 'edit_products' to role successfully.")
                    katello["permissions_v2"] = True
                    data["katello"] = katello
                    save_versions(data)
            else:
                print("  WARNING: Could not find role to repair. Upload may fail.", file=sys.stderr)
        else:
            # Permissions are fine — mark as checked so we skip this next time.
            katello["permissions_v2"] = True
            data["katello"] = katello
            save_versions(data)

    return katello


def _push_katello(rpm_file: str, katello_cfg: dict) -> None:
    """Upload *rpm_file* to the configured Katello repository via the API."""
    if not Path(rpm_file).exists():
        print(f"WARNING: RPM file '{rpm_file}' not found, skipping Katello upload.", file=sys.stderr)
        return

    url        = katello_cfg["url"]
    verify_ssl = katello_cfg.get("ssl_verify", True)
    token      = _katello_token(katello_cfg)
    login      = katello_cfg.get("login", "")
    repo_id    = katello_cfg.get("repository_id")
    auth       = _kat_admin_auth(login, token)

    if not login or not repo_id:
        print("ERROR: Katello config is missing 'login' or 'repository_id'.", file=sys.stderr)
        print("       Re-run 'tuxmigrate status' or reconfigure with a fresh versions.json.", file=sys.stderr)
        return

    rpm_path  = Path(rpm_file)
    file_data = rpm_path.read_bytes()
    file_size = len(file_data)
    checksum  = hashlib.sha256(file_data).hexdigest()
    filename  = rpm_path.name

    print(f"\nUploading {filename} to Katello via API...")

    # Step 1: Create an upload request (scoped to this repository)
    result, err = _kat_post(url, auth, f"/katello/api/v2/repositories/{repo_id}/content_uploads", {}, verify_ssl)
    if err or not result:
        print(f"ERROR: Could not create upload request: {err}", file=sys.stderr)
        return
    upload_id = result.get("upload_id")
    if not upload_id:
        print(f"ERROR: No upload_id in response: {result}", file=sys.stderr)
        return

    # Step 2: PUT the file as multipart/form-data
    boundary = "--------tuxmigrate_boundary"
    body = (
        f"--{boundary}\r\n"
        f'Content-Disposition: form-data; name="size"\r\n\r\n'
        f"{file_size}\r\n"
        f"--{boundary}\r\n"
        f'Content-Disposition: form-data; name="offset"\r\n\r\n'
        f"0\r\n"
        f"--{boundary}\r\n"
        f'Content-Disposition: form-data; name="content"; filename="{filename}"\r\n'
        f"Content-Type: application/octet-stream\r\n\r\n"
    ).encode() + file_data + f"\r\n--{boundary}--\r\n".encode()

    put_url = url.rstrip("/") + f"/katello/api/v2/repositories/{repo_id}/content_uploads/{upload_id}"
    req = urllib.request.Request(put_url, data=body, method="PUT")
    req.add_header("Authorization", auth)
    req.add_header("Content-Type", f"multipart/form-data; boundary={boundary}")
    req.add_header("Accept", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=120, context=_kat_ssl_ctx(verify_ssl)) as resp:
            resp.read()
    except urllib.error.HTTPError as exc:
        detail = ""
        try:
            detail = exc.read().decode()
        except Exception:
            pass
        print(f"ERROR: File upload failed: HTTP {exc.code}: {detail}", file=sys.stderr)
        return
    except Exception as exc:  # noqa: BLE001
        print(f"ERROR: File upload failed: {exc}", file=sys.stderr)
        return

    # Step 3: Import the upload into the repository and publish
    import_payload = {
        "uploads": [{"id": upload_id, "name": filename, "checksum": checksum, "size": file_size}],
        "publish_repository": True,
    }
    result, err = _kat_post(
        url, auth,
        f"/katello/api/v2/repositories/{repo_id}/import_uploads",
        import_payload, verify_ssl,
    )
    if err:
        print(f"ERROR: Failed to import upload into repository: {err}", file=sys.stderr)
    else:
        print(f"  Uploaded and published {filename} to Katello repository.")


def _build_fpm(package_name: str, version: str, maintainer: str, description: str) -> bool:
    output_dir = _rpm_output_dir(package_name)
    output_dir.mkdir(exist_ok=True)
    cmd = [
        "fpm",
        "-s", "dir",
        "-t", "rpm",
        "-n", package_name,
        "-v", version,
        "--after-install", POST_INSTALL_SCRIPT,
        "--maintainer", maintainer,
        "--description", description,
        "--rpm-summary", description,
        "--force",
        "--package", str(output_dir),
        f"{ROLE_DIR}/={_rpm_role_path(package_name)}/",
        f"{SITE_YML}={_rpm_site_yml_path(package_name)}",
    ]
    print(f"\nRunning: {' '.join(cmd)}\n")
    if subprocess.run(cmd).returncode != 0:
        print("ERROR: fpm failed. Check the output above for details.", file=sys.stderr)
        return False
    _print_install_hint(str(output_dir / f"{package_name}-{version}-1.x86_64.rpm"))
    return True


def _build_rpmbuild(
    package_name: str, version: str, maintainer: str, description: str
) -> bool:
    """Generate a minimal .spec file and invoke rpmbuild."""
    install_role = _rpm_role_path(package_name)
    install_site = _rpm_site_yml_path(package_name)
    install_dir  = f"/usr/share/{package_name}"

    # Absolute paths so %install works regardless of rpmbuild's working directory.
    project_root = Path(".").resolve()
    abs_role_dir = project_root / ROLE_DIR
    abs_site_yml = project_root / SITE_YML

    output_dir = _rpm_output_dir(package_name)
    output_dir.mkdir(exist_ok=True)
    abs_output_dir = (project_root / output_dir).resolve()

    changelog_date = datetime.datetime.now().strftime("%a %b %d %Y")

    spec_content = f"""%define _rpmdir {abs_output_dir}

Name:        {package_name}
Version:     {version}
Release:     1%{{?dist}}
Summary:     {description}
License:     MIT
BuildArch:   noarch
Packager:    {maintainer}

%description
{description}

%install
mkdir -p %{{buildroot}}{install_role}
mkdir -p %{{buildroot}}{install_dir}
cp -r {abs_role_dir}/* %{{buildroot}}{install_role}/
cp {abs_site_yml} %{{buildroot}}{install_dir}/

%files
%{{_usr}}/share/{package_name}/

%post
bash {install_dir}/{POST_INSTALL_SCRIPT}

%changelog
* {changelog_date} {maintainer} - {version}-1
- tuxmigrate automated build
"""

    spec_file = Path(f"{package_name}.spec")
    spec_file.write_text(spec_content)
    print(f"\nWrote {spec_file}")

    # Copy post-install script to install dir so %post can reach it at install time
    # rpmbuild needs BUILD/BUILDROOT/RPMS/SOURCES/SPECS/SRPMS dirs
    for d in ["BUILD", "BUILDROOT", "RPMS", "SOURCES", "SPECS", "SRPMS"]:
        Path(d).mkdir(exist_ok=True)

    cmd = [
        "rpmbuild",
        "--define", f"_topdir {Path('.').resolve()}",
        "--define", f"_rpmfilename {package_name}-{version}-1.noarch.rpm",
        "-bb", str(spec_file),
    ]
    print(f"Running: {' '.join(cmd)}\n")
    if subprocess.run(cmd).returncode != 0:
        print("ERROR: rpmbuild failed. Check the output above for details.", file=sys.stderr)
        return False
    _print_install_hint(str(output_dir / f"{package_name}-{version}-1.noarch.rpm"))
    return True


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="tuxmigrate",
        description="RPM-based Ansible configuration migration tool.",
    )
    sub = parser.add_subparsers(dest="command", metavar="COMMAND")

    # build
    build_p = sub.add_parser(
        "build",
        help="Absorb pending changes, bump version, and produce an RPM.",
    )
    build_p.add_argument(
        "--package-name",
        metavar="NAME",
        help="RPM package name (default: value from versions.json or 'tuxmigrate').",
    )
    build_p.add_argument(
        "--maintainer",
        metavar="EMAIL",
        help="RPM maintainer field.",
    )
    build_p.add_argument(
        "--description",
        metavar="TEXT",
        help="RPM description / summary.",
    )
    build_p.add_argument(
        "--build-tool",
        metavar="TOOL",
        choices=SUPPORTED_BUILD_TOOLS,
        help="RPM build utility to use: fpm or rpmbuild (overrides versions.json).",
    )
    bump_group = build_p.add_mutually_exclusive_group()
    bump_group.add_argument(
        "--major",
        dest="bump",
        action="store_const",
        const="major",
        help="Bump the major version (e.g. 1.2.3 -> 2.0.0).",
    )
    bump_group.add_argument(
        "--minor",
        dest="bump",
        action="store_const",
        const="minor",
        help="Bump the minor version (e.g. 1.2.3 -> 1.3.0).",
    )
    bump_group.add_argument(
        "--patch",
        dest="bump",
        action="store_const",
        const="patch",
        help="Bump the patch version (e.g. 1.2.3 -> 1.2.4) [default].",
    )
    build_p.set_defaults(func=cmd_build, bump="patch")

    # status
    status_p = sub.add_parser(
        "status",
        help="Show current version and pending changes.",
    )
    status_p.set_defaults(func=cmd_status)

    # upload
    upload_p = sub.add_parser(
        "upload",
        help="Upload the RPM for a specific version to Katello/Satellite.",
    )
    upload_p.add_argument(
        "version",
        metavar="VERSION",
        help="Version to upload, e.g. 1.0.3",
    )
    upload_p.set_defaults(func=cmd_upload)

    # rebuild
    rebuild_p = sub.add_parser(
        "rebuild",
        help="Re-build the RPM for a specific version without bumping or moving files.",
    )
    rebuild_p.add_argument(
        "version",
        metavar="VERSION",
        help="Version to rebuild, e.g. 1.0.3",
    )
    rebuild_p.add_argument(
        "--upload",
        action="store_true",
        help="Upload the rebuilt RPM to Katello/Satellite afterwards.",
    )
    rebuild_p.set_defaults(func=cmd_rebuild)

    # remove
    remove_p = sub.add_parser(
        "remove",
        help="Move a version or specific playbook back to changes/.",
    )
    remove_group = remove_p.add_mutually_exclusive_group(required=True)
    remove_group.add_argument(
        "--version",
        metavar="VERSION",
        help="Remove all playbooks that belong to VERSION (e.g. 1.0.3).",
    )
    remove_group.add_argument(
        "--playbook",
        metavar="NAME",
        help="Remove a single playbook by its original or stored filename.",
    )
    remove_p.set_defaults(func=cmd_remove)

    args = parser.parse_args()
    ensure_config(args)
    if not args.command:
        parser.print_help()
        sys.exit(0)

    args.func(args)


if __name__ == "__main__":
    main()
